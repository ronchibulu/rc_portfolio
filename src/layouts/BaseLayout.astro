---
// Root layout — D-23 (single BaseLayout, no RootLayout/PageLayout split yet).
// Side-effect imports below are the ONLY place fontsource and globals.css are imported.
// Any other file importing them would cause double-registration (PITFALLS §8).
import '@fontsource/press-start-2p';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Ronald Cheng — Senior Software Engineer and Full-Stack Developer',
  description = 'Portfolio of Ronald Cheng — Senior Software Engineer and Full-Stack Developer specialising in full-stack development and AI-powered applications. React, Next.js, Astro, Three.js, LangChain.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    {/* Phase 11 — SEO / OG / DEPLOY-003 */}
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Ronald Cheng — Senior Software Engineer and Full-Stack Developer portfolio" />
    <meta property="og:locale" content="en_HK" />

    {/* Twitter/X Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    {/* Performance: preconnect to nothing external (self-hosted fonts) */}
  </head>
  <body class="min-h-dvh bg-black text-zinc-100 antialiased">
    <slot />
  </body>
</html>
