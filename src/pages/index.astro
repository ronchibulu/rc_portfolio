---
/*
 * Phase 2 — Landing page composition.
 * Replaces the Phase 1 smoke test (01-03 output).
 *
 * Layout:
 *   BaseLayout > Header (sticky, h-16) > <main> (hero + 3 placeholder sections) > Footer.
 *
 * Hero (HERO-001/002/003/004):
 *   - <HeroTyping> React island mounted with client:only="react" (no SSR output,
 *     zero hydration mismatch risk). HERO-001 (no-JS visibility) is satisfied by the
 *     <noscript> static fallback below the island. Hard rule: complex React islands
 *     use client:only per AGENTS.md.
 *   - Scroll cue: <a href="#projects"> wrapping the ▼ glyph, bobbing via .animate-scrollbob
 *     (defined in Plan 01 globals.css, gated by prefers-reduced-motion: no-preference).
 *
 * Placeholders: three <section>s with one-line copy per 02-UI-SPEC §Placeholder stubs.
 *   Each is min-h-dvh + scroll-mt-16 so smooth-scroll lands below the sticky nav.
 *
 * Canvas compatibility (02-UI-SPEC §Color): hero section has NO background image /
 *   gradient / overlay — only the body's zinc-950 shows through. The Phase 4-6 3D
 *   canvas will slot BEHIND this markup.
 *
 * No 3D, no GSAP, no Motion here — Phase 3+ concerns.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import HeroTyping from '@/components/HeroTyping';
import SceneCanvas from '@/components/canvas/SceneCanvas';
import SceneView from '@/components/canvas/SceneView';

const hero = {
  name: "Hi, I'm Ronald.",
  role: 'Senior Full-Stack Developer',
  tagline: 'Shipping pixel-sharp frontends with purpose.',
};
---

<BaseLayout title="Ronald Cheng — Senior Full-Stack Developer">
  {/* ===== CANVAS LAYER (Phase 4) ===== */}
  {/*
    * Fixed full-viewport R3F canvas behind all HTML content.
    * CSS contract (04-UI-SPEC §Canvas CSS Contract):
    *   - fixed inset-0: covers the full viewport at all breakpoints, no responsive overrides needed.
    *   - z-0: behind all content layers (z-10+).
    *   - pointer-events-none: mouse/touch events pass through to nav, hero, footer.
    *   - aria-hidden="true": decorative 3D background, excluded from a11y tree.
    * client:only="react": no SSR output; canvas hydrates client-side only (AGENTS.md hard rule).
    * NEVER use client:load or client:visible for R3F islands.
    */}
  <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
    <SceneCanvas client:only="react" />
  </div>

  <Header />

  <main>
    {/* =============== HERO =============== */}
    <section id="hero" class="relative z-10 flex min-h-dvh scroll-mt-16 items-center">
      {/*
        * Phase 5 — View tracking region.
        * absolute inset-0: covers the hero section exactly (section is relative z-10).
        * pointer-events-none: mouse/touch events pass through to hero text and scroll cue.
        * SceneView reads this div's bounds via document.getElementById('hero-canvas-view').
        * client:only="react" — hard rule (AGENTS.md): R3F islands never SSR.
        */}
      <div id="hero-canvas-view" class="absolute inset-0 pointer-events-none" />
      <SceneView client:only="react" trackId="hero-canvas-view" />

      <div
        class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 md:py-24 lg:px-12 lg:py-32"
      >
        {/*
          * client:only="react" — no SSR output for this island, zero hydration mismatch.
          * HERO-001 (no-JS visibility) is satisfied by the static <noscript> below.
          * AGENTS.md hard rule: complex React islands use client:only="react".
          */}
        <HeroTyping
          client:only="react"
          name={hero.name}
          role={hero.role}
          tagline={hero.tagline}
        />
        {/* Static fallback for no-JS / pre-hydration (HERO-001) */}
        <noscript>
          <div class="flex flex-col gap-4 md:gap-6">
            <div class="font-pixel text-3xl leading-tight text-zinc-100 sm:text-4xl md:text-5xl lg:text-6xl">
              {hero.name}
            </div>
            <p class="font-pixel text-base leading-snug text-purple-400 sm:text-lg md:text-xl lg:text-2xl">
              {hero.role}
            </p>
            <p class="text-sm leading-relaxed sm:text-base md:text-lg">
              <span class="font-pixel text-purple-400">&gt;_ </span>
              <span class="font-sans text-zinc-500">Shipping </span>
              <span class="font-sans text-yellow-400">pixel-sharp</span>
              <span class="font-sans text-zinc-500"> frontends with purpose.</span>
            </p>
          </div>
        </noscript>
      </div>

      {/* Scroll cue — anchored bottom-center, bobs via .animate-scrollbob (Plan 01 globals.css). */}
      <a
        href="#projects"
        aria-label="Scroll to projects"
        class="absolute bottom-4 left-1/2 inline-flex -translate-x-1/2 animate-scrollbob items-center justify-center rounded-sm p-1 font-pixel text-lg text-yellow-400 transition-colors hover:text-yellow-400 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 md:bottom-6 lg:bottom-8"
      >
        ▼
      </a>
    </section>

    {/* =============== PROJECTS PLACEHOLDER — arriving in Phase 7 =============== */}
    <section
      id="projects"
      class="relative z-10 flex min-h-dvh scroll-mt-16 items-center justify-center px-4 sm:px-6 lg:px-12"
    >
      <p class="text-center font-pixel text-sm text-zinc-500">
        Projects — arriving in Phase 7.
      </p>
    </section>

    {/* =============== ABOUT PLACEHOLDER — arriving in Phase 9 =============== */}
    <section
      id="about"
      class="relative z-10 flex min-h-dvh scroll-mt-16 items-center justify-center px-4 sm:px-6 lg:px-12"
    >
      <p class="text-center font-pixel text-sm text-zinc-500">
        About Me — arriving in Phase 9.
      </p>
    </section>

    {/* =============== CONTACT PLACEHOLDER — footer is contact =============== */}
    <section
      id="contact"
      class="relative z-10 flex min-h-dvh scroll-mt-16 items-center justify-center px-4 sm:px-6 lg:px-12"
    >
      <p class="text-center font-pixel text-sm text-zinc-500">
        Contact — see footer below.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>
