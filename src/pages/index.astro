---
/*
 * Phase 2/6 — Landing page composition.
 *
 * Phase 2: Header, Footer, HeroTyping, placeholder sections.
 * Phase 6: Scroll pin wrapper for GSAP camera fly-in, tagline overlays,
 *          ScrollNarrative island for tagline fades + hard-cut $activeSection.
 *
 * Layout:
 *   BaseLayout > Header (sticky, h-16) > <main> (pin wrapper > hero + taglines, OS sections) > Footer.
 *
 * Scroll pin structure (Phase 6):
 *   #scene-scroll-pin — outer div, min-h-[200dvh], ScrollTrigger trigger.
 *   section#hero       — sticky top-0 h-dvh, stays fixed while outer scrolls.
 *   At 100% scroll the pin releases and #projects snaps into view (hard cut).
 */
import ScrollNarrative from '@/components/canvas/ScrollNarrative';
import SceneCanvas from '@/components/canvas/SceneCanvas';
import GPUDetector from '@/components/GPUDetector';
import HeroFallback from '@/components/HeroFallback';
import OSScreen from '@/components/OSScreen';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import HeroTyping from '@/components/HeroTyping';
import BaseLayout from '@/layouts/BaseLayout.astro';

const hero = {
  name: "Hi, I'm Ronald.",
  role: 'Senior Full-Stack Developer',
  tagline: 'Shipping pixel-sharp frontends with purpose.',
};
---

<BaseLayout title="Ronald Cheng — Senior Full-Stack Developer">
  {/* ===== GPU TIER DETECTION (Phase 10) ===== */}
  {/* Runs detect-gpu on mount, sets $gpuTier nanostore. Returns null. */}
  <GPUDetector client:only="react" />

  {/* ===== CANVAS LAYER (Phase 4/5/10) ===== */}
  {/*
    * Fixed full-viewport R3F canvas — z-0, pointer-events-none, aria-hidden.
    * SceneCanvas owns the View + GameSetupScene (Phase 5 architecture fix).
    * Phase 6: GameSetupScene now contains the GSAP ScrollTrigger camera hook.
    * Phase 10: SceneCanvas reads $gpuTier — returns null on tier 1 (low/mobile).
    */}
  <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
    <SceneCanvas client:only="react" heroViewId="hero-canvas-view" />
  </div>

  {/*
    * Drei View tracking div — SEPARATE sibling to the canvas container.
    * Must NOT be an ancestor/descendant of the <canvas> element; Drei's
    * IntersectionObserver uses the canvas as a measurement root and breaks
    * when the track element is inside the canvas container.
    *
    * fixed inset-0 ensures getBoundingClientRect() always returns the full
    * viewport rect regardless of scroll position. The old placement
    * (absolute inset-0 inside sticky #hero) caused Drei's scissor to shrink
    * and drift upward once the sticky pin released (parent bottom < hero height).
    *
    * z-[-1] puts it behind the canvas layer so it never intercepts paint.
    */}
  <div id="hero-canvas-view" class="pointer-events-none fixed inset-0 z-[-1]" aria-hidden="true"></div>

  {/* ===== SCROLL NARRATIVE (Phase 6) ===== */}
  {/*
    * Pure scroll-orchestration island — no DOM output, returns null.
    * Owns tagline scrub timeline + hard-cut $activeSection transition.
    * client:only="react" — no SSR output needed.
    */}
  <ScrollNarrative client:only="react" />

  <Header />

  <main>
    {/* ===== HERO FALLBACK (Phase 10) ===== */}
    {/* Shown instead of scroll narrative on low-tier GPU / mobile. Returns null on tier 2/3. */}
    <HeroFallback client:only="react" />

    {/* =============== SCROLL PIN WRAPPER (Phase 6) =============== */}
    {/*
      * Outer div is the ScrollTrigger trigger (#scene-scroll-pin).
      * min-h-[200dvh] gives the camera fly-in its scroll travel range (~1 viewport).
      * 100dvh not 100vh (AGENTS.md hard rule).
      * z-10 so hero text sits above the fixed canvas (z-0).
      */}
    <div id="scene-scroll-pin" class="relative z-10 min-h-[200dvh]">
      {/*
        * Sticky inner — stays at viewport top while outer div scrolls.
        * h-dvh = exactly one dynamic viewport height (AGENTS.md hard rule).
        * overflow-hidden prevents tagline text from leaking outside viewport.
        */}
      <section
        id="hero"
        class="sticky top-0 flex h-dvh items-center overflow-hidden scroll-mt-16"
        aria-label="Hero"
      >
        {/*
          * Phase 5 — The Drei View tracking region is the canvas container
          * div (fixed inset-0, id="hero-canvas-view") defined above.
          * No separate tracking div is needed here; the fixed container
          * always reports the full viewport rect to Drei's scissor.
          */}

        {/* ── Hero text — fades out early in scroll (ScrollNarrative targets #hero-text-content) ── */}
        <div id="hero-text-content" class="relative z-10 w-full px-4 py-16 sm:px-6 md:py-24 lg:px-12 lg:py-32">
          <div class="mx-auto max-w-7xl">
            <HeroTyping
              client:only="react"
              name={hero.name}
              role={hero.role}
              tagline={hero.tagline}
            />
            {/* Static fallback for no-JS / pre-hydration (HERO-001) */}
            <noscript>
              <div class="flex flex-col gap-4 md:gap-6">
                <div class="font-pixel text-3xl leading-tight text-zinc-100 sm:text-4xl md:text-5xl lg:text-6xl">
                  {hero.name}
                </div>
                <p class="font-pixel text-base leading-snug text-purple-400 sm:text-lg md:text-xl lg:text-2xl">
                  {hero.role}
                </p>
                <p class="text-sm leading-relaxed sm:text-base md:text-lg">
                  <span class="font-pixel text-purple-400">&gt;_ </span>
                  <span class="font-sans text-zinc-500">Shipping </span>
                  <span class="font-sans text-yellow-400">pixel-sharp</span>
                  <span class="font-sans text-zinc-500"> frontends with purpose.</span>
                </p>
              </div>
            </noscript>
          </div>
        </div>

        {/* ── Tagline overlays (Phase 6) ── */}
        {/*
          * Start opacity-0. ScrollNarrative.tsx scrubs these in/out during fly-in.
          * aria-hidden="true" — decorative overlays, content already in HeroTyping.
          * Reduced-motion: display:none via globals.css @media rule.
          */}
        <div
          id="fly-tagline-1"
          aria-hidden="true"
          class="absolute bottom-24 left-0 right-0 z-20 px-4 text-center font-pixel text-xs text-purple-400 opacity-0 sm:px-6 sm:text-sm lg:px-12 lg:text-base"
        >
          Full-Stack · Frontend · AI
        </div>
        <div
          id="fly-tagline-2"
          aria-hidden="true"
          class="absolute bottom-14 left-0 right-0 z-20 px-4 text-center font-pixel text-xs text-zinc-500 opacity-0 sm:px-6 sm:text-sm lg:px-12"
        >
          5 years shipping production-grade frontends
        </div>

        {/* Scroll cue — anchored bottom-center, bobs via .animate-scrollbob */}
        <a
          id="scroll-cue"
          href="#projects"
          aria-label="Scroll to projects"
          class="absolute bottom-4 left-1/2 z-30 inline-flex -translate-x-1/2 animate-scrollbob items-center justify-center rounded-sm p-1 font-pixel text-lg text-yellow-400 transition-colors hover:text-yellow-400 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-black md:bottom-6 lg:bottom-8"
        >
          ▼
        </a>

        {/* Blackout overlay — fades from transparent to black as camera enters monitor (Phase 6) */}
        <div
          id="fly-blackout"
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 z-40 bg-black opacity-0"
        />
      </section>
    </div>
    {/* ── End #scene-scroll-pin ── */}

    {/* =============== OS SCREEN — Phase 7 =============== */}
    {/*
      * Fixed overlay controlled by $activeSection nanostore.
      * Appears when camera fly-in completes ($activeSection === 'os').
      * #projects sentinel preserves nav anchor scroll target.
      */}
    <div id="projects" class="h-0 overflow-hidden" aria-hidden="true" />
    <OSScreen client:only="react" />

    {/* =============== ABOUT — Phase 9 Timeline =============== */}
    <section
      id="about"
      class="relative z-10 flex min-h-dvh scroll-mt-16 items-center justify-center px-4 sm:px-6 lg:px-12"
    >
      <p class="text-center font-pixel text-sm text-zinc-500">
        About Me — arriving in Phase 9.
      </p>
    </section>

    {/* =============== CONTACT — footer is contact =============== */}
    <section
      id="contact"
      class="relative z-10 flex min-h-dvh scroll-mt-16 items-center justify-center px-4 sm:px-6 lg:px-12"
    >
      <p class="text-center font-pixel text-sm text-zinc-500">
        Contact — see footer below.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>
