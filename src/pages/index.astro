---
/*
 * Phase 2/6 — Landing page composition.
 *
 * Phase 2: Header, Footer, HeroTyping, placeholder sections.
 * Phase 6: Scroll pin wrapper for GSAP camera fly-in, tagline overlays,
 *          ScrollNarrative island for tagline fades + hard-cut $activeSection.
 *
 * Layout:
 *   BaseLayout > Header (sticky, h-16) > <main> (pin wrapper > hero + taglines, OS sections) > Footer.
 *
 * Scroll pin structure (Phase 6):
 *   #scene-scroll-pin — outer div, min-h-[200dvh], ScrollTrigger trigger.
 *   section#hero       — sticky top-0 h-dvh, stays fixed while outer scrolls.
 *   At 100% scroll the pin releases and #projects snaps into view (hard cut).
 */
import AIAgentChat from '@/components/AIAgentChat';
import CenterTextReveal from '@/components/CenterTextReveal';
import ScrollNarrative from '@/components/canvas/ScrollNarrative';
import SceneCanvas from '@/components/canvas/SceneCanvas';
import GPUDetector from '@/components/GPUDetector';
import HeroFallback from '@/components/HeroFallback';
import NavTransition from '@/components/NavTransition';
import OSScreen from '@/components/OSScreen';
import PageIntro from '@/components/PageIntro';
import PixelCursor from '@/components/PixelCursor';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import HeroTyping from '@/components/HeroTyping';
import BaseLayout from '@/layouts/BaseLayout.astro';

const hero = {
  name: "Hi, I'm Ronald.",
  role: 'Senior Full-Stack Software Engineer',
  tagline: 'Shipping pixel-sharp applications with purpose.',
};
---

<BaseLayout>
  {/* ===== GPU TIER DETECTION (Phase 10) ===== */}
  {/* Runs detect-gpu on mount, sets $gpuTier nanostore. Returns null. */}
  <GPUDetector client:only="react" />

  {/*
    * SSR-rendered boot cover — paints black over everything (including the
    * sticky Header z-40 and OSScreen z-50) before any JS runs. Without this,
    * the header flashes for one frame because <PageIntro> is client:only and
    * therefore has zero SSR output; the browser paints the hero+header at
    * initial HTML commit, then React hydrates and covers the viewport. This
    * div closes that gap. PageIntro removes it in a useLayoutEffect on mount
    * — i.e. after React's own overlay is committed but before the browser
    * paints — so the swap is seamless.
    *
    * Inline style used for zIndex because project rule forbids Tailwind
    * arbitrary values (z-[60]).
    */}
  <div
    id="page-intro-boot"
    aria-hidden="true"
    style="position:fixed;inset:0;z-index:60;background:#000"
  ></div>

  {/* ===== BOOT OVERLAY — loading gate + pixel reveal ===== */}
  {/*
    * Full-viewport overlay (zIndex 60) that covers header, canvas, hero and
    * OS screen until:
    *   1. the 3D scene finishes loading (shows LOADING x% during this phase), then
    *   2. the PixelReveal dissolve animation completes.
    * During both phases the body scroll is locked, so the camera fly-in
    * never plays against a partially loaded scene. ScrollTrigger.refresh()
    * fires once after unlock so pinned measurements account for the
    * now-scrollable document.
    */}
  <PageIntro client:only="react" />

  {/* ===== NAV TRANSITION — pixel cover/reveal on header anchor clicks ===== */}
  {/*
    * Intercepts clicks on header anchors (#projects, #about, #contact, and
    * the brand "/" link). Runs a chunky pixel-cover animation, jumps scroll
    * to the target anchor, then plays the reverse pixel-reveal — so every
    * nav hop feels like an 8-bit screen wipe. zIndex 70 in the overlay so
    * it sits above PageIntro (60), OSScreen (50), and Header (40).
    */}
  <NavTransition client:only="react" />

  {/* ===== CANVAS LAYER (Phase 4/5/10) ===== */}
  {/*
    * Fixed full-viewport R3F canvas — z-0, pointer-events-none, aria-hidden.
    * SceneCanvas owns the View + GameSetupScene (Phase 5 architecture fix).
    * Phase 6: GameSetupScene now contains the GSAP ScrollTrigger camera hook.
    * Phase 10: SceneCanvas reads $gpuTier — returns null only on tier 1
    * (WebGL unsupported). Mobile and desktop Safari render the scene at
    * lower DPR instead of being bounced to HeroFallback.
    */}
  <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
    <SceneCanvas client:only="react" heroViewId="hero-canvas-view" />
  </div>

  {/*
    * Drei View tracking div — SEPARATE sibling to the canvas container.
    * Must NOT be an ancestor/descendant of the <canvas> element; Drei's
    * IntersectionObserver uses the canvas as a measurement root and breaks
    * when the track element is inside the canvas container.
    *
    * fixed inset-0 ensures getBoundingClientRect() always returns the full
    * viewport rect regardless of scroll position. The old placement
    * (absolute inset-0 inside sticky #hero) caused Drei's scissor to shrink
    * and drift upward once the sticky pin released (parent bottom < hero height).
    *
    * z-[-1] puts it behind the canvas layer so it never intercepts paint.
    */}
  <div id="hero-canvas-view" class="pointer-events-none fixed right-0 inset-y-0 z-[-1] w-full" aria-hidden="true"></div>

  {/* ===== SCROLL NARRATIVE (Phase 6) ===== */}
  {/*
    * Pure scroll-orchestration island — no DOM output, returns null.
    * Owns tagline scrub timeline + hard-cut $activeSection transition.
    * client:only="react" — no SSR output needed.
    */}
  <ScrollNarrative client:only="react" />

  <Header />

  <main class="-mt-16">
    {/* ===== HERO FALLBACK (Phase 10) ===== */}
    {/* Shown instead of scroll narrative on low-tier GPU / mobile. Returns null on tier 2/3. */}
    <HeroFallback client:only="react" />

    {/* =============== SCROLL PIN WRAPPER (Phase 6) =============== */}
    {/*
      * Outer div is the ScrollTrigger trigger (#scene-scroll-pin).
      * min-h-[300dvh] gives the camera fly-in ~2 viewports of scroll travel —
      * longer than the original 200dvh so the fly-in reads cinematically
      * instead of blasting past the scene in a single page flick.
      * 100dvh not 100vh (AGENTS.md hard rule).
      * z-10 so hero text sits above the fixed canvas (z-0).
      */}
    <div id="scene-scroll-pin" class="relative z-10 min-h-[300dvh]">
      {/*
        * Sticky inner — stays at viewport top while outer div scrolls.
        * h-dvh = exactly one dynamic viewport height (AGENTS.md hard rule).
        * overflow-hidden prevents tagline text from leaking outside viewport.
        */}
      <section
        id="hero"
        class="sticky top-0 flex h-dvh items-center overflow-hidden scroll-mt-16"
        aria-label="Hero"
      >
        {/*
          * Phase 5 — The Drei View tracking region is the canvas container
          * div (fixed inset-0, id="hero-canvas-view") defined above.
          * No separate tracking div is needed here; the fixed container
          * always reports the full viewport rect to Drei's scissor.
          */}

        {/* ── Hero text — fades out early in scroll (ScrollNarrative targets #hero-text-content) ── */}
        {/*
          * Text column sits in the left portion of the viewport. The 3D
          * gaming setup renders offset to the right (SCENE_X_OFFSET in
          * GameSetupScene.tsx) so the desk + monitor live in the right
          * portion and no longer overlap the "Hi, I'm Ronald." text.
          */}
        <div id="hero-text-content" class="relative mx-auto z-10 max-w-7xl w-full px-4 py-16 sm:px-6 md:py-24 lg:px-12 lg:py-32">
          <div class="max-w-xl">
            <HeroTyping
              client:only="react"
              name={hero.name}
              role={hero.role}
              tagline={hero.tagline}
            />
            {/* Static fallback for no-JS / pre-hydration (HERO-001) */}
            <noscript>
              <div class="flex flex-col gap-4 md:gap-6">
                <div class="font-pixel text-xl leading-tight text-zinc-100 sm:text-2xl md:text-3xl lg:text-4xl">
                  {hero.name}
                </div>
                <p class="font-pixel text-sm leading-snug text-purple-400 sm:text-base md:text-lg lg:text-xl">
                  {hero.role}
                </p>
                <p class="text-xs leading-relaxed sm:text-sm md:text-base">
                  <span class="font-pixel text-purple-400">&gt;_ </span>
                  <span class="font-sans text-zinc-500">Shipping </span>
                  <span class="font-sans text-yellow-400">pixel-sharp</span>
                  <span class="font-sans text-zinc-500"> frontends with purpose.</span>
                </p>
              </div>
            </noscript>
          </div>
        </div>

        {/* ── Tagline overlays (Phase 6) ── */}
        {/*
          * Start opacity-0. ScrollNarrative.tsx scrubs these in/out during fly-in.
          * aria-hidden="true" — decorative overlays, content already in HeroTyping.
          * Reduced-motion: display:none via globals.css @media rule.
          */}
        <!-- <div
          id="fly-tagline-1"
          aria-hidden="true"
          class="absolute bottom-24 left-0 right-0 z-20 px-4 text-center font-pixel text-xs text-purple-400 opacity-0 sm:px-6 sm:text-sm lg:px-12 lg:text-base"
        >
          Full-Stack · Frontend · AI
        </div>
        <div
          id="fly-tagline-2"
          aria-hidden="true"
          class="absolute bottom-14 left-0 right-0 z-20 px-4 text-center font-pixel text-xs text-zinc-500 opacity-0 sm:px-6 sm:text-sm lg:px-12"
        >
          5 years shipping production-grade frontends
        </div> -->

        {/* Scroll cue — anchored bottom-center, bobs via .animate-scrollbob */}
        <a
          id="scroll-cue"
          href="#projects"
          aria-label="Scroll to projects"
          class="absolute bottom-4 left-1/2 z-30 inline-flex -translate-x-1/2 animate-scrollbob items-center justify-center rounded-sm p-1 font-pixel text-lg text-yellow-400 transition-colors hover:text-yellow-400 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-black md:bottom-6 lg:bottom-8"
        >
          ▼
        </a>
      </section>
    </div>
    {/* ── End #scene-scroll-pin ── */}

    {/*
     * Blackout overlay — fades transparent → black as camera enters monitor (Phase 6).
     *
     * Fixed inset-0 so it covers the ENTIRE viewport instead of being clipped to
     * the sticky hero. DOM-placed between #scene-scroll-pin and #post-flyin-pin
     * so (with matching z-10) the paint order is:
     *   canvas (z-0) → scene-scroll-pin → blackout → post-flyin-pin (text).
     * Result: the blackout covers the 3D scene everywhere while leaving the
     * text reveal above it visible. Once the fly-in scrub hits progress 1 the
     * ScrollTrigger locks final state, so the backdrop stays black through the
     * post-flyin typing section. Scrubs in reverse on scroll-up.
     */}
    <div
      id="fly-blackout"
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-10 bg-black opacity-0"
    />

    {/* =============== AI AGENT CHAT SCENE =============== */}
    {/*
      * AIAgentChat is a FIXED viewport-centered overlay (a sibling of
      * #fly-blackout — not a child of the pin below). The pin itself is
      * a pure scroll spacer: its only job is to give the chat scene some
      * scroll distance to "live" across before #post-flyin-pin takes over.
      *
      * Why fixed instead of sticky: a sticky stage inside the pin would
      * make the chat slide up from the viewport bottom as the pin's top
      * approaches the viewport top. We want the chat to materialise in
      * the centre of the screen the moment the camera fly-in completes,
      * so the overlay is detached from layout flow and faded in/out by
      * GSAP onEnter/onLeave on the pin's boundaries.
      *
      * Pin height 250dvh = ~1.5 viewports of scroll — enough for the
      * cascade (~3-4s of streamed text) plus a beat of reading time.
      */}
    <AIAgentChat client:only="react" />
    <div
      id="ai-agent-pin"
      class="relative z-10 min-h-[250dvh]"
      aria-hidden="true"
    ></div>
    {/* ── End #ai-agent-pin ── */}

    {/* =============== POST-FLYIN TEXT REVEAL — Phase 12 =============== */}
    {/*
      * After the camera fly-in blackout completes, this pin scrolls the user
      * through a four-line tagline reveal before the OSScreen activates.
      *
      * Why a separate pin instead of extending #scene-scroll-pin:
      *   The fly-in's ScrollTrigger uses `end: 'bottom top'` on #scene-scroll-pin.
      *   Lengthening that pin would stretch the camera animation out. A new
      *   sibling pin keeps the fly-in timing untouched.
      *
      * Height: 250dvh (~1.5 viewports of scroll) — enough for the four typed
      * lines + hold-beat at the end without feeling draggy.
      *
      * The pin itself is transparent (no bg-black) so while it emerges from
      * viewport bottom during the tail of the fly-in, the 3D canvas stays
      * visible behind it — no black "text section" seam cuts into the scene.
      * The full-viewport #fly-blackout (sibling above) handles backdrop fade:
      * it hits opacity 1 at the end of the fly-in and stays locked, so by the
      * time this pin takes over the viewport the backdrop is already black.
      *
      * OSScreen activation: handled by ScrollNarrative via onEnter on this
      * pin's `bottom top`. See ScrollNarrative.tsx.
      *
      * Height bumped from 250dvh → 400dvh so after the typing completes the
      * user gets a clearly readable hold-beat with the full quote before
      * #post-flyin-pin releases and OSScreen takes over. Pairs with a larger
      * TAIL_HOLD ratio in CenterTextReveal.tsx so the extra scroll distance
      * biases toward "text sits complete on screen" instead of stretching
      * typing itself.
      */}
    <div id="post-flyin-pin" class="relative z-10 min-h-[400dvh]">
      <section
        id="post-flyin-stage"
        class="sticky top-0 flex h-dvh items-center justify-center overflow-hidden"
        aria-label="Role and experience summary"
      >
        <CenterTextReveal client:only="react" />
      </section>
    </div>
    {/* ── End #post-flyin-pin ── */}

    {/* =============== SCROLL HEADROOM — Phase 12 fix =============== */}
    {/*
      * One viewport of black filler AFTER the post-flyin pin.
      *
      * Why this exists: ScrollTrigger's onEnter fires when the scroll position
      * CROSSES the trigger point — it needs the user to be able to scroll
      * PAST `#post-flyin-pin`'s `bottom bottom`. Without this filler, the
      * trigger point coincides with the document's maximum scroll position
      * (sentinels are h-0 and the Footer is short), which means scroll can
      * only *reach* the trigger, never *pass* it, and OSScreen never
      * activates.
      *
      * Once OSScreen activates, its useEffect locks body overflow so this
      * filler becomes inert — the user can only exit via wheel-up (handled
      * inside OSScreen). Background is kept bg-black to continue the blackout
      * seamlessly from the fly-in.
      *
      * aria-hidden: decorative filler, no content.
      */}
    <div
      aria-hidden="true"
      class="bg-black"
      style="height: 100dvh;"
    />

    {/* =============== OS SCREEN — Phase 7 =============== */}
    {/*
      * Fixed overlay controlled by $activeSection nanostore.
      * Appears when the post-flyin pin exits ($activeSection === 'os') and
      * takes over the entire viewport (z-50, above Header z-40). Phase 12
      * adds a PixelReveal canvas intro inside OSScreen that plays once on
      * first activation.
      *
      * #projects sentinel preserves nav anchor scroll behaviour — clicking
      * "Projects" in the header scrolls the page to the end of the post-flyin
      * pin, which triggers the 'os' activeSection and reveals OSScreen.
      *
      * #about sentinel is here so the header's "About" link also lands at the
      * end of the post-flyin pin → OSScreen → user opens the About Me folder.
      *
      * About Me / Contact content is delivered inside OSScreen (AboutDialog)
      * and the site Footer respectively — no separate stub sections in flow.
      */}
    <div id="projects" class="h-0 overflow-hidden" aria-hidden="true" />
    <div id="about" class="h-0 overflow-hidden" aria-hidden="true" />
    {/* #contact sentinel — nav "Contact" link resolves here; user then scrolls
        past the scene pin into OSScreen, where the real contact info lives in
        the site Footer (visible below OSScreen when the user scrolls up out of
        it, and accessible via tab order). Keeping the anchor avoids 404-style
        broken-link feedback from the header. */}
    <div id="contact" class="h-0 overflow-hidden" aria-hidden="true" />
    <OSScreen client:only="react" />
  </main>

  {/* ===== PIXEL CURSOR TRAIL =====
    * Chunky 8-bit trail rendered on a fixed canvas (z-50). Pairs with the
    * static pixel-arrow.png sprite set as the OS cursor in globals.css.
    * Self-gates on prefers-reduced-motion, (pointer: coarse), and tier 1
    * GPU. Mounted after OSScreen so it paints above the OS shell while
    * staying below NavTransition (z 70) and PageIntro boot cover (z 60).
    */}
  <PixelCursor client:only="react" />

  <Footer />
</BaseLayout>
