---
/*
 * Phase 2 — Header.astro
 * Sticky top nav per 02-UI-SPEC §Nav Contract.
 *
 * Structure: <header> > <nav aria-label="Primary"> > inner flex row with brand left, <ul> right.
 * Height: h-16 (64px) — MUST stay synced with globals.css scroll-padding-top: 4rem.
 * Background: solid zinc-950 at sm:, zinc-950/80 + backdrop-blur-sm at md:+ (readable over
 * future 3D canvas in Phase 4+).
 * Accent: text-zinc-500 resting → text-purple-400 on hover + focus-visible.
 * Tap targets: min-h-11 inline-flex items-center → guaranteed ≥44px iOS HIG on sm:.
 *
 * Mobile (<md:): nav links collapse into hamburger panel toggled by button.
 * Breakpoint-driven (no isMobile store). Animations are CSS-driven via data-state attr,
 * JS only flips the attr + aria-expanded. Pixel chunky bars match the 8-bit theme.
 */
---

<header
  id="site-header"
  data-state="closed"
  class="sticky top-0 z-40 w-full border-b border-zinc-800 bg-zinc-950 md:bg-zinc-950/80 md:backdrop-blur-sm"
>
  <nav
    aria-label="Primary"
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-12"
  >
    {/* Brand — RC, links to page top */}
    <a
      href="/"
      class="font-pixel text-sm text-zinc-100 transition-colors hover:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 md:text-base"
    >
      RC
    </a>

    {/* Desktop nav — hidden below md:, shown md:+ */}
    <ul class="hidden items-center gap-6 md:flex lg:gap-8">
      <li>
        <a
          href="#projects"
          class="inline-flex min-h-11 items-center px-2 py-2 font-pixel text-sm text-zinc-500 transition-colors hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          Projects
        </a>
      </li>
      <li>
        <a
          href="#about"
          class="inline-flex min-h-11 items-center px-2 py-2 font-pixel text-sm text-zinc-500 transition-colors hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          About
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="inline-flex min-h-11 items-center px-2 py-2 font-pixel text-sm text-zinc-500 transition-colors hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          Contact
        </a>
      </li>
    </ul>

    {/* Mobile hamburger button — chunky pixel bars, animates to X via [data-state="open"] on header */}
    <button
      id="mobile-nav-toggle"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      class="hamburger-btn group inline-flex h-11 w-11 items-center justify-center text-zinc-300 transition-colors hover:text-purple-400 active:text-purple-400 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 md:hidden"
    >
      <span class="hamburger relative block h-4 w-6" aria-hidden="true">
        <span class="bar bar-top absolute left-0 top-0 block h-1 w-6 bg-current"></span>
        <span class="bar bar-mid absolute left-0 top-1.5 block h-1 w-6 bg-current"></span>
        <span class="bar bar-bot absolute left-0 top-3 block h-1 w-6 bg-current"></span>
      </span>
    </button>
  </nav>

  {/* Mobile dropdown panel — hidden md:+, animated via [data-state] on header */}
  <div
    id="mobile-nav-panel"
    class="mobile-nav-panel absolute inset-x-0 top-full overflow-hidden border-zinc-800 bg-zinc-950 md:hidden"
  >
    <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-4 pt-2 pb-4 sm:px-6">
      <li class="mobile-nav-item" style="--i: 0;">
        <a
          href="#projects"
          data-mobile-nav-link
          class="flex min-h-11 items-center border-l-2 border-transparent px-3 py-3 font-pixel text-sm text-zinc-300 transition-colors hover:border-purple-400 hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          Projects
        </a>
      </li>
      <li class="mobile-nav-item" style="--i: 1;">
        <a
          href="#about"
          data-mobile-nav-link
          class="flex min-h-11 items-center border-l-2 border-transparent px-3 py-3 font-pixel text-sm text-zinc-300 transition-colors hover:border-purple-400 hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          About
        </a>
      </li>
      <li class="mobile-nav-item" style="--i: 2;">
        <a
          href="#contact"
          data-mobile-nav-link
          class="flex min-h-11 items-center border-l-2 border-transparent px-3 py-3 font-pixel text-sm text-zinc-300 transition-colors hover:border-purple-400 hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          Contact
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  /* Hamburger bars — chunky, sharp pixel feel. Steppy timing matches the 8-bit theme. */
  .hamburger .bar {
    transform-origin: center;
    transition:
      transform 220ms cubic-bezier(0.5, 0, 0.5, 1),
      opacity 160ms ease-out,
      background-color 160ms ease-out;
  }

  /* Tiny purple glow on hover/focus — keeps the CRT vibe */
  .hamburger-btn:hover .bar,
  .hamburger-btn:focus-visible .bar {
    box-shadow: 0 0 4px rgb(192 132 252 / 0.6);
  }

  /* OPEN STATE — bars morph into X */
  #site-header[data-state='open'] .bar-top {
    transform: translateY(6px) rotate(45deg);
  }
  #site-header[data-state='open'] .bar-mid {
    transform: scaleX(0);
    opacity: 0;
  }
  #site-header[data-state='open'] .bar-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Panel — slide down + fade in. max-height + opacity transition is cheap and steppy */
  .mobile-nav-panel {
    max-height: 0;
    opacity: 0;
    border-bottom-width: 0;
    transition:
      max-height 260ms cubic-bezier(0.5, 0, 0.5, 1),
      opacity 200ms ease-out,
      border-bottom-width 0ms linear 260ms;
  }
  #site-header[data-state='open'] .mobile-nav-panel {
    max-height: 24rem;
    opacity: 1;
    border-bottom-width: 1px;
    transition:
      max-height 260ms cubic-bezier(0.5, 0, 0.5, 1),
      opacity 200ms ease-out 60ms,
      border-bottom-width 0ms linear 0ms;
  }

  /* Per-link stagger — each item fades + slides in after panel opens */
  .mobile-nav-item {
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 180ms ease-out,
      transform 180ms ease-out;
    transition-delay: 0ms;
  }
  #site-header[data-state='open'] .mobile-nav-item {
    opacity: 1;
    transform: translateX(0);
    transition-delay: calc(120ms + var(--i, 0) * 60ms);
  }

  /* Reduced motion — hard cut, no slide/rotate easing */
  @media (prefers-reduced-motion: reduce) {
    .hamburger .bar,
    .mobile-nav-panel,
    .mobile-nav-item {
      transition: none !important;
    }
  }
</style>

<script>
  // Hamburger toggle — flips data-state on header; CSS handles all animation.
  const header = document.getElementById('site-header');
  const btn = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav-panel');

  function setOpen(open: boolean) {
    if (!header || !btn) return;
    header.setAttribute('data-state', open ? 'open' : 'closed');
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute(
      'aria-label',
      open ? 'Close navigation menu' : 'Open navigation menu'
    );
  }

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });

  // Close after tapping any link.
  panel?.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // Close on Escape, return focus to button.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      (btn as HTMLButtonElement).focus();
    }
  });

  // Auto-close if viewport crosses up into md: while open.
  const mq = window.matchMedia('(min-width: 768px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>
