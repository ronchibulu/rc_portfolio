        class="inline-flex min-h-11 items-center py-2 text-xs text-zinc-500 transition-colors hover:text-purple-400 active:text-purple-400 active:opacity-75 focus-visible:rounded-sm focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-purple-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950 sm:text-sm"
