{
  "name": "ronald-cheng-portfolio",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint --no-errors-on-unmatched src && astro check",
    "format": "biome format --write --no-errors-on-unmatched src *.mjs *.json && prettier --write \"src/**/*.astro\"",
    "check": "biome check --no-errors-on-unmatched src && astro check",
    "optimize-model": "gltf-transform dedup gaming_setup_v12.glb tmp_dedup.glb && gltf-transform prune tmp_dedup.glb tmp_pruned.glb && gltf-transform flatten tmp_pruned.glb tmp_flat.glb && gltf-transform weld tmp_flat.glb tmp_welded.glb && gltf-transform draco tmp_welded.glb public/models/gaming_setup_v12.glb --quantize-position 10 --quantize-normal 8 --quantize-texcoord 10 && rm -f tmp_dedup.glb tmp_pruned.glb tmp_flat.glb tmp_welded.glb"
  },
  "dependencies": {
    "@astrojs/react": "^4",
    "@astrojs/vercel": "^9",
    "@fontsource/press-start-2p": "^5.2.7",
    "@gsap/react": "^2.1.2",
    "@nanostores/react": "^1.1.0",
    "@react-three/drei": "^10",
    "@react-three/fiber": "^9",
    "@tailwindcss/vite": "^4",
    "astro": "^5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "detect-gpu": "^5.0.70",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.12",
    "lucide-react": "^1.8.0",
    "motion": "^12",
    "nanostores": "^1.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "three": "^0.176",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^1",
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
